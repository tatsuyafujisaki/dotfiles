// https://geminicli.com/docs/reference/configuration
// How to deploy this file:
// ln -f -s ~/Documents/GitHub/dotfiles/gemini/settings.json ~/.gemini/settings.json
{
  "billing": {
    "overageStrategy": "never"
  },
  "general": {
    "defaultApprovalMode": "auto_edit",
    "enableNotifications": true,
    "preferredEditor": "antigravity",
    "sessionRetention": {
      "maxCount": 0
    }
  },
  "ide": {
    "enabled": true
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true,
    "autoAddToPolicyByDefault": true
  },
  "tools": {
    "disableLLMCorrection": false
  }
}
