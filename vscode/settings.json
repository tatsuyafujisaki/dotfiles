// How to deploy this file:
// ln -f -s "$HOME/Documents/GitHub/dotfiles/vscode/settings.json" "$HOME/Library/Application Support/Antigravity/User"
// ln -f -s "$HOME/Documents/GitHub/dotfiles/vscode/settings.json" "$HOME/Library/Application Support/Code/User"
{
  "chat.mcp.discovery.enabled": {
    "antigravity": false
  },
  "chat.tools.terminal.autoApprove": {
    "dart": true,
    "go": true
  },
  "dart.flutterGenerateLocalizationsOnSave": "allIfDirty",
  "dart.flutterHotReloadOnSave": "all", // https://docs.flutter.dev/tools/hot-reload#how-to-perform-a-hot-reload
  "dart.hotReloadOnSave": "allIfDirty",
  "dart.runPubGetOnNestedProjects": "both",
  "debug.console.historySuggestions": false,
  "debug.openExplorerOnEnd": true,
  "debug.showVariableTypes": true,
  "debug.terminal.clearBeforeReusing": true,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.find.history": "never",
  "editor.find.replaceHistory": "never",
  "editor.find.globalFindClipboard": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.autoGuessEncoding": true,
  "files.autoSave": "afterDelay", // https://docs.flutter.dev/tools/hot-reload#how-to-perform-a-hot-reload
  "files.hotExit": "off",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "geminicodeassist.agentYoloMode": true,
  "geminicodeassist.enableTelemetry": false,
  "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
  "geminicodeassist.inlineSuggestions.suggestionSpeed": "Fast",
  "git.allowForcePush": true,
  "git.allowNoVerifyCommit": true,
  "git.autofetch": true,
  "git.autoStash": true,
  "git.confirmEmptyCommits": false,
  "git.confirmForcePush": false,
  "git.confirmNoVerifyCommit": false,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.fetchOnPull": true,
  "git.followTagsWhenSync": true,
  "git.postCommitCommand": "sync",
  "git.pruneOnFetch": true,
  "git.pullBeforeCheckout": true,
  "git.rebaseWhenSync": true,
  "git.replaceTagsWhenPull": true,
  // https://golangci-lint.run/docs/welcome/integrations/#visual-studio-code
  "go.lintTool": "golangci-lint-v2",
  "go.lintFlags": [
    "--path-mode=abs",
    "--fast-only"
  ],
  "go.formatTool": "custom",
  "go.alternateTools": {
    "customFormatter": "golangci-lint-v2"
  },
  "go.formatFlags": [
    "fmt",
    "--stdin"
  ],
  // Golang settings not in https://golangci-lint.run/docs/welcome/integrations/#visual-studio-code
  "go.inlayHints.assignVariableTypes": true,
  "go.inlayHints.compositeLiteralFields": true,
  "go.inlayHints.compositeLiteralTypes": true,
  "go.inlayHints.constantValues": true,
  "go.inlayHints.functionTypeParameters": true,
  "go.inlayHints.ignoredError": true,
  "go.inlayHints.parameterNames": true,
  "go.inlayHints.rangeVariableTypes": true,
  "go.lintOnSave": "workspace",
  // https://marketplace.visualstudio.com/items?itemName=golang.Go#:~:text=For%20better%20syntax%20highlighting,%20we%20recommend%20enabling%20semantic%20highlighting%20by%20turning%20on%20Gopls'%20ui.semanticTokens%20setting.%20%22gopls%22:%20{%20%22ui.semanticTokens%22:%20true%20}
  "gopls": {
    "ui.semanticTokens": true
  },
  "html.format.preserveNewLines": false,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "javascript.suggest.completeFunctionCalls": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "search.globalFindClipboard": true,
  "search.quickOpen.includeHistory": false,
  // If smartCase is true, the search is case-insensitive only if the search term is all lowercase.
  // If smartCase is false, the search is always case-insensitive.
  // "search.smartCase": true,
  "security.workspace.trust.enabled": false,
  "task.quickOpen.history": 0,
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.shellIntegration.history": 0,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.completeFunctionCalls": true,
  "window.nativeTabs": true,
  "window.restoreWindows": "none",
  "workbench.commandPalette.history": 0,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.restoreViewState": false,
  "workbench.settings.editor": "json",
  "workbench.settings.openDefaultSettings": true,
  "workbench.startupEditor": "none",
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  }
}
